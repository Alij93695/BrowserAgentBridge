{
  "manifest_version": 3,
  "name": "BrowserAgentBridge",
  "version": "1.0.0",
  "description": "A generic, developer-friendly bridge for AI agents to control Chrome securely in the background.",
  "permissions": [
    "tabs",
    "scripting",
    "webNavigation",
    "storage",
    "alarms"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
